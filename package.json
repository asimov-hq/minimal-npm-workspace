{
  "name": "@asimov/minimal-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run -ws build",
    "typecheck": "npm run -ws typecheck",
    "clean": "npm run -ws clean",
    "dev:server": "npm run -w @asimov/minimal-server dev",
    "dev:web": "npm run -w @asimov/minimal-web dev",
    "start:server": "npm run -w @asimov/minimal-server start",
    "start:cli": "npm run -w @asimov/minimal-cli start"
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "tsx": "^4.8.1",
    "typescript": "^5.8.0"
  }
}
