{
  "name": "my-app",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run -ws build",
    "typecheck": "npm run -ws typecheck",
    "clean": "npm run -ws clean",
    "dev:server": "npm run -w @my-app/server dev",
    "dev:web": "npm run -w @my-app/web dev",
    "start:server": "npm run -w @my-app/server start",
    "start:cli": "npm run -w @my-app/cli start"
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "typescript": "^5.8.0"
  }
}
